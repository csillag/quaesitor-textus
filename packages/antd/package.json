{
  "name": "@quaesitor-textus/antd",
  "version": "0.1.0",
  "type": "module",
  "files": ["dist", "src"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
